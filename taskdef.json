
{
	"family": "my-task",
	"taskRoleArn": "arn:aws:iam::463367046625:role/ecsInstanceRole",
	"containerDefinitions": [{
		"name": "my-task",
		"image": "867267088667.dkr.ecr.us-east-1.amazonaws.com/adfarm-tfw-admin:GIT_COMMIT",
		"cpu": 300,
		"memory": 300,
		"memoryReservation": 200,
		"volumesFrom": [],
		"portMappings": [{
			"hostPort": 80,
			"containerPort": 80,
			"protocol": "tcp"
		}],
		"essential": true,
        "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "ecs/testing",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "testing"
        }
      },
      "environment": [],
      "mountPoints": []
    }
  ]
}
