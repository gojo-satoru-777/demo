{
    "family": "my-task",
    "containerDefinitions": [
        {
            "name": "my-task",
            "image": "463367046625.dkr.ecr.eu-north-1.amazonaws.com/aws/website:GIT_COMMIT",
            "cpu": 300,
            "memory": 300,
            "memoryReservation": 200,
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "name": "my-task-80-tcp"
                }
            ],
            "essential": true,
            "environment": [],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "ecs/testing",
                    "awslogs-region": "eu-north-1",
                    "awslogs-stream-prefix": "testing"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "taskRoleArn": "arn:aws:iam::463367046625:role/ecsInstanceRole",
    "executionRoleArn": "arn:aws:iam::463367046625:role/ecsTaskExecutionRole",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "EC2"
    ],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}
